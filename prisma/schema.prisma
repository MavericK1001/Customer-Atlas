// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model AppInstall {
  id             Int      @id @default(autoincrement())
  shopDomain     String   @unique
  accessToken    String
  merchantUserId Int?
  merchantUser   MerchantUser? @relation(fields: [merchantUserId], references: [id], onDelete: SetNull)
  planTier       String   @default("free")
  billingStatus  String   @default("active")
  shopifySubscriptionId String?
  trialEndsAt    DateTime?
  lastSyncAt     DateTime?
  lastSyncStatus String?
  lastSyncError  String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  affiliateReferrals AffiliateReferral[]

  @@index([merchantUserId])
  @@index([shopDomain, billingStatus])
}

model MerchantUser {
  id           Int         @id @default(autoincrement())
  email        String      @unique
  passwordHash String
  name         String?
  role         String      @default("merchant")
  installs     AppInstall[]
  affiliateProfile AffiliateProfile?
  affiliateApplications AffiliateApplication[]
  reviewedAffiliateApplications AffiliateApplication[] @relation("AffiliateApplicationReviewer")
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}

model Customer {
  id                Int                 @id @default(autoincrement())
  shopDomain        String
  shopifyCustomerId String
  email             String?
  totalOrders       Int                 @default(0)
  totalSpent        Decimal             @db.Decimal(12, 2)
  averageOrderValue Decimal             @db.Decimal(12, 2)
  predictedLtv      Decimal             @db.Decimal(12, 2)
  lastOrderDate     DateTime?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  orders            Order[]
  segmentMemberships SegmentMembership[]

  @@unique([shopDomain, shopifyCustomerId])
  @@index([shopDomain])
}

model Order {
  id             Int      @id @default(autoincrement())
  shopDomain     String
  shopifyOrderId String
  customerId     Int?
  orderValue     Decimal  @db.Decimal(12, 2)
  products       Json
  createdAt      DateTime
  updatedAt      DateTime @updatedAt
  customer       Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  @@unique([shopDomain, shopifyOrderId])
  @@index([shopDomain])
  @@index([customerId])
  @@index([shopDomain, createdAt])
}

model Segment {
  id            Int                 @id @default(autoincrement())
  shopDomain    String
  segmentName   String
  rules         Json
  customerCount Int                 @default(0)
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  memberships   SegmentMembership[]

  @@unique([shopDomain, segmentName])
  @@index([shopDomain])
}

model SegmentMembership {
  id         Int      @id @default(autoincrement())
  customerId Int
  segmentId  Int
  createdAt  DateTime @default(now())
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  segment    Segment  @relation(fields: [segmentId], references: [id], onDelete: Cascade)

  @@unique([customerId, segmentId])
  @@index([segmentId])
}

model Insight {
  id               Int      @id @default(autoincrement())
  shopDomain       String
  insightType      String
  message          String
  potentialRevenue Decimal  @db.Decimal(12, 2)
  createdAt        DateTime @default(now())
  archivedAt       DateTime?

  @@index([shopDomain])
  @@index([shopDomain, archivedAt])
}

model AffiliateApplication {
  id            Int      @id @default(autoincrement())
  email         String
  contactName   String
  companyName   String?
  websiteUrl    String?
  audienceNotes String?
  status        String   @default("pending")
  reviewerNotes String?
  merchantUserId Int?
  merchantUser  MerchantUser? @relation(fields: [merchantUserId], references: [id], onDelete: SetNull)
  reviewedById  Int?
  reviewedBy    MerchantUser? @relation("AffiliateApplicationReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  reviewedAt    DateTime?

  @@index([email])
  @@index([status])
  @@index([merchantUserId])
}

model AffiliateProfile {
  id             Int      @id @default(autoincrement())
  merchantUserId Int      @unique
  merchantUser   MerchantUser @relation(fields: [merchantUserId], references: [id], onDelete: Cascade)
  status         String   @default("pending")
  commissionRate Decimal  @db.Decimal(5, 2) @default(10.00)
  approvedAt     DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  links          AffiliateReferralLink[]
  referrals      AffiliateReferral[]
  apiKeys        AffiliateApiKey[]
  payouts        AffiliatePayout[]

  @@index([status])
}

model AffiliateReferralLink {
  id          Int      @id @default(autoincrement())
  affiliateId Int
  affiliate   AffiliateProfile @relation(fields: [affiliateId], references: [id], onDelete: Cascade)
  code        String   @unique
  label       String?
  isDefault   Boolean  @default(false)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  expiresAt   DateTime?
  referrals   AffiliateReferral[]

  @@index([affiliateId])
  @@index([affiliateId, isActive])
}

model AffiliateReferral {
  id             Int      @id @default(autoincrement())
  affiliateId    Int
  affiliate      AffiliateProfile @relation(fields: [affiliateId], references: [id], onDelete: Cascade)
  referralLinkId Int?
  referralLink   AffiliateReferralLink? @relation(fields: [referralLinkId], references: [id], onDelete: SetNull)
  appInstallId   Int      @unique
  appInstall     AppInstall @relation(fields: [appInstallId], references: [id], onDelete: Cascade)
  referredShopDomain String
  commissionRate Decimal  @db.Decimal(5, 2)
  commissionAmount Decimal @db.Decimal(12, 2) @default(0)
  status         String   @default("pending")
  source         String   @default("install-ref")
  attributedAt   DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([affiliateId, referredShopDomain])
  @@index([affiliateId])
  @@index([referredShopDomain])
}

model AffiliateApiKey {
  id          Int      @id @default(autoincrement())
  affiliateId Int
  affiliate   AffiliateProfile @relation(fields: [affiliateId], references: [id], onDelete: Cascade)
  name        String
  keyPrefix   String
  keyHash     String
  lastUsedAt  DateTime?
  revokedAt   DateTime?
  expiresAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([affiliateId])
  @@index([affiliateId, revokedAt])
}

model AffiliatePayout {
  id          Int      @id @default(autoincrement())
  affiliateId Int
  affiliate   AffiliateProfile @relation(fields: [affiliateId], references: [id], onDelete: Cascade)
  periodStart DateTime
  periodEnd   DateTime
  amount      Decimal  @db.Decimal(12, 2)
  status      String   @default("calculated")
  notes       String?
  paidAt      DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([affiliateId])
  @@index([affiliateId, status])
}
